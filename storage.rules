rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // POST IMAGES — /posts/{userId}/{fileName}
    match /posts/{userId}/{fileName} {
      // Anyone can read (public post images)
      allow read: if true;

      // Only authenticated user matching userId can upload
      // Max file size: 5MB
      // Allowed content types: image/jpeg, image/png, image/gif, image/webp
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }

    // AVATARS — /avatars/{userId}/{fileName}
    match /avatars/{userId}/{fileName} {
      // Anyone can read
      allow read: if true;

      // Only owner can upload their avatar
      // Max file size: 2MB
      // Image types only
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // ALL OTHER PATHS — deny everything
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
